{
  "name": "@tik-choco/mistai",
  "version": "0.6.3",
  "private": false,
  "description": "Shared LLM Network library: wire protocol, consumer/provider services, voice (TTS/STT), OpenAI-compatible upstream client, and preact hooks.",
  "type": "module",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tik-choco-lab/mistai.git"
  },
  "bugs": {
    "url": "https://github.com/tik-choco-lab/mistai/issues"
  },
  "homepage": "https://github.com/tik-choco-lab/mistai#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preact": {
      "types": "./dist/preact/index.d.ts",
      "default": "./dist/preact/index.js"
    },
    "./llm-config": {
      "types": "./dist/llm-config.d.ts",
      "default": "./dist/llm-config.js"
    },
    "./ui.css": "./dist/preact/ui.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').copyFileSync('src/preact/ui.css','dist/preact/ui.css')\"",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "preact": "^10.29.1",
    "typescript": "~6.0.2",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "preact": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "preact": {
      "optional": true
    }
  }
}
